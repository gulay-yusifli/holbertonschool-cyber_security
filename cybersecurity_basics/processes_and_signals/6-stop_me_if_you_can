#!/usr/bin/env bash
# Stops 4-to_infinity_and_beyond without using kill or killall

for pid in /proc/[0-9]*; do
    if [ -r "$pid/comm" ]; then
        if grep -q "4-to_infinity_and_beyond" "$pid/cmdline" 2>/dev/null; then
            echo "Stopping process $(basename "$pid")"
            /bin/kill -TERM "$(basename "$pid")"
        fi
    fi
done
